#!/usr/bin/env bash
# vault — thin dispatcher for the user's self-hosted Bitwarden vault.
# All logic lives in lib.sh.

set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=./lib.sh
source "$SCRIPT_DIR/lib.sh"

cmd="${1:-help}"
shift 2>/dev/null || true

# `doctor`, `setup`, `help` and `status` don't need deps to be fully present
# (they report what's missing). Other commands do.
case "$cmd" in
  help|--help|-h|doctor|setup|status) ;;
  *) _require_deps || exit 1 ;;
esac

case "$cmd" in
  get)          vault_get          "$@" ;;
  list)         vault_list         "$@" ;;
  list-fields)  vault_list_fields  "$@" ;;
  env)          vault_env          "$@" ;;
  create)       vault_create       "$@" ;;
  update)       vault_update       "$@" ;;
  set-field)    vault_set_field    "$@" ;;
  delete-field) vault_delete_field "$@" ;;
  delete)       vault_delete       "$@" ;;
  sync)         vault_sync               ;;
  status)       vault_status             ;;
  setup)        vault_setup              ;;
  doctor)       vault_doctor             ;;
  help|--help|-h) vault_help             ;;
  *) _err "unknown command: $cmd"; vault_help >&2; exit 1 ;;
esac
